{
  "name": "@pride7/frameseq",
  "version": "0.3.0",
  "description": "Build presentations like interfaces with a linear TypeScript DSL.",
  "keywords": [
    "slides",
    "presentation",
    "typescript",
    "pdf",
    "dsl"
  ],
  "license": "MIT",
  "type": "module",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js"
    },
    "./globals": {
      "types": "./lib/globals.d.ts",
      "default": "./lib/index.js"
    }
  },
  "bin": {
    "frameseq": "scripts/frameseq.mjs"
  },
  "files": [
    "docs",
    "lib",
    "public",
    "scripts/frameseq.mjs",
    "src/main.ts",
    "src/renderer.ts",
    "src/styles.css",
    "src/theme.ts",
    "src/vite-env.d.ts",
    "index.html",
    "vite.config.ts",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "dev": "node scripts/frameseq.mjs dev slides.ts",
    "build": "npm run build:package && npm run build:demo",
    "build:package": "vite build --config vite.lib.config.ts && tsc -p tsconfig.publish.json",
    "build:demo": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "check": "tsc --noEmit",
    "test": "npm run build && node scripts/theme-test.mjs && node scripts/smoke-test.mjs && node scripts/beamer-smoke-test.mjs && node scripts/minimal-academic-smoke-test.mjs",
    "frameseq": "node scripts/frameseq.mjs",
    "export:pdf": "node scripts/frameseq.mjs pdf slides.ts --output output/pdf/frameseq.pdf",
    "pack:check": "node scripts/package-test.mjs",
    "release:check": "npm test && npm run pack:check",
    "prepack": "npm run build:package"
  },
  "dependencies": {
    "katex": "^0.16.22",
    "puppeteer": "^24.16.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@types/katex": "^0.16.7",
    "@types/node": "^24.0.0",
    "typescript": "^5.8.3"
  }
}
