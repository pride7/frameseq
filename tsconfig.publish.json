{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "emitDeclarationOnly": true,
    "declaration": true,
    "declarationMap": true,
    "rootDir": "./src",
    "outDir": "./lib"
  },
  "include": [
    "src/core.ts",
    "src/globals.ts",
    "src/index.ts",
    "src/script.ts",
    "src/semantic.ts"
  ]
}
